document.querySelectorAll('section[data-current-styles]').forEach(section=>{const raw=section.getAttribute('data-current-styles');if(!raw.includes('customSectionHeight')&&!raw.includes('customContentWidth'))return;try{const parsed=JSON.parse(raw);let normalized=JSON.stringify(parsed).replace(/"customSectionHeight":(\d+)/,'"customSectionHeight": $1').replace(/"customContentWidth":(\d+)/,'"customContentWidth": $1');section.setAttribute('data-current-styles',normalized)}catch(e){const fixed=raw.replace(/"customSectionHeight":(\d+)/,'"customSectionHeight": $1').replace(/"customContentWidth":(\d+)/,'"customContentWidth": $1');section.setAttribute('data-current-styles',fixed)}});